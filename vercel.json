{
  "rewrites": [
    { "source": "/", "destination": "/alan-damasceno.html" }
  ],
  "redirects": [
    { "source": "/alan", "destination": "/", "permanent": true },
    { "source": "/lead", "destination": "/captura.html", "permanent": true },
    { "source": "/dash", "destination": "/dashboard-decisao.html", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)\\.vcf",
      "headers": [
        { "key": "Content-Type", "value": "text/vcard; charset=utf-8" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"alan-damasceno.vcf\"" }
      ]
    }
  ]
}
